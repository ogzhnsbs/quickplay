{
  "manifest_version": 3,
  "name": "QuickPlay",
  "version": "1.0.0",
  "description": "Speed up any video with hover-activated controls. Click a speed or skip forward.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background/background.ts"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "QuickPlay Settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.ts"],
      "css": ["content/styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
